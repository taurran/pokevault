# Normalize line endings: store LF in the repo, check out native per platform.
* text=auto

# Shell scripts MUST be LF — they run on macOS/Linux (CRLF breaks the shebang).
*.sh text eol=lf

# Windows-native scripts stay CRLF.
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Treat these as text (normalize)
*.md   text
*.txt  text
*.yaml text
*.yml  text
*.json text
*.cursorrules text
